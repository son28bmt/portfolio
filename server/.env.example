PORT=5000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=portfolio
DB_USER=portfolio_user
DB_PASS=your_mysql_password
DB_SYNC_ON_START=false
DB_SYNC_ALTER=false
DB_RETRY_MS=5000

JWT_SECRET=change_this_to_a_long_random_secret
ADMIN_USERNAMES=admin
ADMIN_JWT_EXPIRES=7d
CORS_ORIGINS=https://nguyenquangson.id.vn,https://admin.nguyenquangson.id.vn,http://localhost:5173,http://localhost:5174
NODE_ENV=production

R2_ACCOUNT_ID=your_r2_account_id
R2_BUCKET_NAME=your_r2_bucket_name
R2_S3_ENDPOINT=https://your_r2_account_id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://pub-your-r2-public-domain-or-r2dev
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

PROJECT_IMAGE_MAX_MB=10

PUBLIC_SITE_URL=https://nguyenquangson.id.vn
SITEMAP_URL=https://api.nguyenquangson.id.vn/sitemap.xml
SITEMAP_CACHE_MS=300000

DONATE_BANK_BIN=970422
DONATE_ACCOUNT_NO=your_bank_account_number
DONATE_ACCOUNT_NAME=YOUR_ACCOUNT_NAME
DONATE_MIN_AMOUNT=10000
DONATE_MAX_AMOUNT=20000000
DONATE_ORDER_EXPIRE_MINUTES=15
SEPAY_WEBHOOK_SECRET=your_sepay_webhook_secret

# Optional fallback/default bank account config.
# Preferred flow: add connected bank accounts in Admin > Ngan hang.
# Keep these set so the system still has a default before DB config is saved.
PAYMENT_BANK_DEFAULT_KEY=default
PAYMENT_BANK_DEFAULT_LABEL=Tai khoan mac dinh

# Optional static multi-bank fallback if you do not want to manage banks in Admin.
# PAYMENT_BANK_ACCOUNTS=[{"key":"mb","label":"MB Bank","bankBin":"970422","accountNo":"280703333333333","accountName":"NGUYEN QUANG SON"}]
# PAYMENT_BANK_1_KEY=mb
# PAYMENT_BANK_1_LABEL=MB Bank
# PAYMENT_BANK_1_BIN=970422
# PAYMENT_BANK_1_ACCOUNT_NO=280703333333333
# PAYMENT_BANK_1_ACCOUNT_NAME=NGUYEN QUANG SON

MARKET_BANK_BIN=970422
MARKET_ACCOUNT_NO=your_bank_account_number
MARKET_ACCOUNT_NAME=YOUR_ACCOUNT_NAME
MARKET_WEBHOOK_LOG_PATH=./logs/webhook-sepay.log

WALLET_BANK_BIN=970422
WALLET_ACCOUNT_NO=your_bank_account_number
WALLET_ACCOUNT_NAME=YOUR_ACCOUNT_NAME
WALLET_MIN_AMOUNT=10000
WALLET_MAX_AMOUNT=20000000
WALLET_TOPUP_EXPIRE_MINUTES=15
WALLET_PAYMENT_PREFIX=WAL

EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
MARKET_FROM_NAME=Cho so tu dong

TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key
GUEST_CHAT_TOKEN_EXPIRES=30d

TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

MARKET_SUPPLIER_SYNC_ENABLED=true
MARKET_SUPPLIER_SYNC_INTERVAL_MS=60000
MARKET_SMM_PANEL_URL=
MARKET_SMM_PANEL_KEY=
CARD_PROVIDER_BASE_URL=
CARD_PROVIDER_PARTNER_ID=
CARD_PROVIDER_PARTNER_KEY=
CARD_PROVIDER_WALLET_NUMBER=
